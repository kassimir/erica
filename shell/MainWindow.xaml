<Window
    x:Class="Erica.Shell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Erica">

    <Grid x:Name="RootGrid" Background="#FF0D0D0D">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="QuakeRow" Height="0" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            x:Name="QuakePanel"
            Grid.Row="0"
            Background="#FF161616"
            BorderBrush="#FF2A2A2A"
            BorderThickness="0,0,0,1">
            <Grid Padding="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <TextBlock
                        x:Name="QuakeOutput"
                        Foreground="#FFE8E8E8"
                        FontFamily="Consolas"
                        TextWrapping="Wrap" />
                </ScrollViewer>
                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="QuakeInput"
                        Grid.Column="0"
                        AcceptsReturn="True"
                        PlaceholderText="Command — use Send or F5"
                        TextWrapping="Wrap"
                        MinHeight="72" />
                    <Button
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        VerticalAlignment="Bottom"
                        Click="QuakeSend_Click"
                        Content="Send" />
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="#FF6A6A6A"
                FontSize="18"
                Text="Erica" />
        </Grid>

        <Border
            Grid.Row="2"
            Background="#FF111111"
            BorderBrush="#FF222222"
            BorderThickness="0,1,0,0"
            Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="StatusLeft"
                    VerticalAlignment="Center"
                    Foreground="#FF9A9A9A"
                    Text="Ready" />
                <TextBlock
                    x:Name="StatusRight"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Foreground="#FF6A6A6A"
                    Text="Ctrl+Space palette · Ctrl+` console · Ctrl+Shift+V voice (stub)" />
            </Grid>
        </Border>

        <Border
            x:Name="PaletteOverlay"
            Grid.RowSpan="3"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="#CC000000"
            Visibility="Collapsed">
            <Border
                Margin="48"
                Padding="16"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Background="#FF1A1A1A"
                BorderBrush="#FF333333"
                BorderThickness="1"
                CornerRadius="6"
                MaxWidth="720">
                <StackPanel>
                    <TextBlock Margin="0,0,0,8" Foreground="#FFB0B0B0" Text="Command palette" />
                    <TextBox
                        x:Name="PaletteInput"
                        Margin="0,0,0,8"
                        PlaceholderText="Type a command and press Enter"
                        KeyDown="PaletteInput_KeyDown" />
                    <TextBlock Foreground="#FF6A6A6A" FontSize="12" Text="Esc to close" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
