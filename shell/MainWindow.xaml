<Window
    x:Class="Erica.Shell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Erica"
    RequestedTheme="Dark">

    <Grid x:Name="RootGrid" Background="#FF0D0D0D">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="ChromeRowDefinition" Height="0" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Optional top strip for Windowed mode: drag + exit -->
        <Border
            x:Name="WindowChromeBar"
            Grid.Row="0"
            Height="32"
            VerticalAlignment="Top"
            Background="#FF141414"
            BorderBrush="#FF2A2A2A"
            BorderThickness="0,0,0,1"
            Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border
                    x:Name="TitleBarDragRegion"
                    Background="Transparent"
                    HorizontalAlignment="Stretch" />
                <Button
                    x:Name="ExitWindowChromeButton"
                    Grid.Column="1"
                    Margin="0,0,8,0"
                    Padding="12,4"
                    Click="ExitWindowChrome_Click"
                    Content="Exit"
                    FontSize="12" />
            </Grid>
        </Border>

        <!-- Main chromeless content -->
        <Grid Grid.Row="1" Background="#FF0D0D0D">
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="#FF5C5C5C"
                FontSize="20"
                FontWeight="SemiLight"
                Text="Erica" />
        </Grid>

        <!-- Quake-style console -->
        <Border
            x:Name="QuakeSlide"
            Grid.Row="1"
            Height="280"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            Background="#FF161616"
            BorderBrush="#FF2A2A2A"
            BorderThickness="0,0,0,1"
            Canvas.ZIndex="10"
            IsHitTestVisible="False">
            <Border.RenderTransform>
                <CompositeTransform x:Name="QuakeTransform" TranslateY="-280" />
            </Border.RenderTransform>
            <Grid Padding="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ScrollViewer
                    x:Name="QuakeScrollViewer"
                    Grid.Row="0"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
                    <TextBlock
                        x:Name="QuakeOutput"
                        Foreground="#FFE8E8E8"
                        FontFamily="Consolas"
                        TextWrapping="Wrap" />
                </ScrollViewer>
                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="QuakeInput"
                        Grid.Column="0"
                        AcceptsReturn="True"
                        PlaceholderText="Command — Send or F5 (streams from agent)"
                        TextWrapping="Wrap"
                        MinHeight="72" />
                    <Button
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        VerticalAlignment="Bottom"
                        Click="QuakeSend_Click"
                        Content="Send" />
                </Grid>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border
            Grid.Row="2"
            Background="#FF111111"
            BorderBrush="#FF222222"
            BorderThickness="0,1,0,0"
            Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="StatusConnection"
                    VerticalAlignment="Center"
                    Foreground="#FF9A9A9A"
                    Text="Agent: …" />
                <TextBlock
                    x:Name="StatusMode"
                    Grid.Column="1"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#FF8AB4D8"
                    Text="Mode: —" />
                <TextBlock
                    x:Name="StatusError"
                    Grid.Column="2"
                    Margin="16,0,0,0"
                    MaxWidth="360"
                    VerticalAlignment="Center"
                    Foreground="#FFFF6B6B"
                    Text=""
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    x:Name="StatusActivity"
                    Grid.Column="3"
                    Margin="16,0,16,0"
                    VerticalAlignment="Center"
                    Foreground="#FF6A6A6A"
                    TextTrimming="CharacterEllipsis"
                    Text="" />
                <TextBlock
                    x:Name="StatusRight"
                    Grid.Column="4"
                    VerticalAlignment="Center"
                    Foreground="#FF5A5A5A"
                    FontSize="11"
                    Text="Ctrl+Space palette · Ctrl+` console · Ctrl+Shift+V voice" />
            </Grid>
        </Border>

        <!-- Command palette overlay -->
        <Border
            x:Name="PaletteOverlay"
            Grid.RowSpan="3"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="#CC000000"
            Canvas.ZIndex="100"
            Visibility="Collapsed">
            <Border
                Margin="48"
                Padding="16"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Background="#FF1A1A1A"
                BorderBrush="#FF333333"
                BorderThickness="1"
                CornerRadius="6"
                MaxWidth="720">
                <StackPanel>
                    <TextBlock Margin="0,0,0,8" Foreground="#FFB0B0B0" Text="Command palette" />
                    <TextBox
                        x:Name="PaletteInput"
                        Margin="0,0,0,8"
                        PlaceholderText="Type a command and press Enter (POST /execute via agent)"
                        KeyDown="PaletteInput_KeyDown" />
                    <TextBlock Foreground="#FF6A6A6A" FontSize="12" Text="Esc to close · thin client to agent" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
